<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0"
         metadata-complete="true">

    <display-name>Impact-Siswa</display-name>

    <filter>
        <filter-name>authFilter</filter-name>
        <filter-class>com.impactsiswa.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>authFilter</filter-name>
        <url-pattern>/app/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>authServlet</servlet-name>
        <servlet-class>com.impactsiswa.servlet.AuthServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>authServlet</servlet-name>
        <url-pattern>/login</url-pattern>
        <url-pattern>/register</url-pattern>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>dashboardServlet</servlet-name>
        <servlet-class>com.impactsiswa.servlet.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>dashboardServlet</servlet-name>
        <url-pattern>/app/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>eventServlet</servlet-name>
        <servlet-class>com.impactsiswa.servlet.EventServlet</servlet-class>
        <multipart-config>
            <max-file-size>5242880</max-file-size>
            <max-request-size>7340032</max-request-size>
            <file-size-threshold>1048576</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>eventServlet</servlet-name>
        <url-pattern>/app/events</url-pattern>
        <url-pattern>/app/manage-events</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>eventImageServlet</servlet-name>
        <servlet-class>com.impactsiswa.servlet.EventImageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>eventImageServlet</servlet-name>
        <url-pattern>/app/event-images/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>hourLogServlet</servlet-name>
        <servlet-class>com.impactsiswa.servlet.HourLogServlet</servlet-class>
        <multipart-config>
            <max-file-size>5242880</max-file-size>
            <max-request-size>7340032</max-request-size>
            <file-size-threshold>1048576</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>hourLogServlet</servlet-name>
        <url-pattern>/app/hours</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>proofImageServlet</servlet-name>
        <servlet-class>com.impactsiswa.servlet.ProofImageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>proofImageServlet</servlet-name>
        <url-pattern>/app/proofs/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>approvalServlet</servlet-name>
        <servlet-class>com.impactsiswa.servlet.ApprovalServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>approvalServlet</servlet-name>
        <url-pattern>/app/approvals</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>userAdminServlet</servlet-name>
        <servlet-class>com.impactsiswa.servlet.UserAdminServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>userAdminServlet</servlet-name>
        <url-pattern>/app/users</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>affiliationServlet</servlet-name>
        <servlet-class>com.impactsiswa.servlet.AffiliationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>affiliationServlet</servlet-name>
        <url-pattern>/app/affiliations</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>profileServlet</servlet-name>
        <servlet-class>com.impactsiswa.servlet.ProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>profileServlet</servlet-name>
        <url-pattern>/app/profile</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
